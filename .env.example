PORT=3000
NODE_ENV=development

# Neon connection string (recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# Email (for verification emails)
# For local testing you can set EMAIL_TRANSPORT=ethereal and leave the rest blank.
EMAIL_TRANSPORT=ethereal
EMAIL_FROM="No Reply <noreply@example.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Frontend URL used to build verification links (can be your API URL too)
APP_BASE_URL=http://localhost:3000

